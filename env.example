# Meta WhatsApp Cloud API bilgileri (developers.facebook.com/apps üzerinden alınır)
WHATSAPP_TOKEN=EAAG...buraya_kalici_access_token
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890

# Webhook dogrulamasi icin siz belirlersiniz (rastgele guclu bir string yazin)
VERIFY_TOKEN=cok-gizli-dogrulama-anahtari

# Toplanan bilgilerin iletilecegi acente/ekip WhatsApp numarasi (basinda ulke kodu, orn: 905xxxxxxxxx)
AGENT_WHATSAPP_NUMBER=905xxxxxxxxx

# Sunucu portu
PORT=3000

# Temsilci paneli (siteniz.railway.app/panel) icin giris bilgileri
PANEL_USERNAME=admin
PANEL_PASSWORD=cok-guclu-bir-sifre-yazin
